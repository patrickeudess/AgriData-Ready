tr:nth-child(even){background:#F5F5F5}
.subtitle{color:#666;font-style:italic;font-size:12pt;text-align:center;margin-bottom:16pt}
.box{background:#E8F5E9;padding:8pt 12pt;border-left:4pt solid #4CAF50;margin:8pt 0}
